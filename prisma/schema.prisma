datasource db {
  provider = "postgresql"
  url      = DATABASE_URL
}

generator client {
  provider = "prisma-client-js"
}

model Card {
  id           Int      @id @default(autoincrement())
  name         String
  type         String   @default("Baseball")
  grade        String
  market_price Float    @default(0.0)
  createdAt    DateTime @default(now())
}